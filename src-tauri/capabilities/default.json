{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Ariadne — allows the webview to listen for backend-emitted events (e.g. agent:event) and use the shell/dialog plugins.",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "shell:default",
    "dialog:default",
    "notification:default",
    "core:window:allow-request-user-attention"
  ]
}
